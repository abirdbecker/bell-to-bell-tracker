# ── Admin + GitHub write access (set these in Vercel → Project → Environment Variables) ──

# Password for the /admin login.
ADMIN_PASSWORD=change-me-to-something-long

# Optional: separate secret used to sign the admin session cookie.
# If unset, the cookie is signed with ADMIN_PASSWORD (fine for a single admin).
ADMIN_SESSION_SECRET=

# Fine-grained GitHub Personal Access Token with "Contents: Read and write"
# scoped to ONLY the abirdbecker/bell-to-bell-tracker repo. This is what lets
# the /admin page and the submission form commit schools.json / pending.json.
GITHUB_TOKEN=

# Repo coordinates (defaults shown; override if you fork/rename).
GITHUB_OWNER=abirdbecker
GITHUB_REPO=bell-to-bell-tracker
GITHUB_BRANCH=main

# ── Weekly discovery job (GitHub Actions secret, NOT a Vercel env var) ──
# Used only by scripts/discover.js in .github/workflows/discover.yml.
ANTHROPIC_API_KEY=
